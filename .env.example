RAG_PORT=8787
CORS_ORIGIN=*

# Free local AI provider. Install Ollama and run: ollama pull llama3.1:8b
LLM_PROVIDER=ollama
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI AI brief generation
OPENAI_API_KEY=
# Optional: rotate only keys you own. Comma-separated.
OPENAI_API_KEYS=
OPENAI_MODEL=gpt-5
OPENAI_BASE_URL=https://api.openai.com/v1
# Required for any non-api.openai.com endpoint that you own and trust.
ALLOW_CUSTOM_OPENAI_BASE_URL=false

# Live evidence providers
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
APIFY_TOKEN=
BRIGHT_DATA_API_KEY=
GOOGLE_ADS_DEVELOPER_TOKEN=
META_ACCESS_TOKEN=
SEARCHAPI_API_KEY=
WHATSAPP_ACCESS_TOKEN=
TWILIO_AUTH_TOKEN=
