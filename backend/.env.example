# Example .env.local — copy this to .env.local and fill in your keys
# .env.local is gitignored; keep secrets there, not in .env

# =============================================================================
# LLM PROVIDERS — pick one or more; orchestrator auto-failover
# =============================================================================

# Groq (free tier, very fast — https://console.groq.com/keys)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Mistral AI (free tier — https://console.mistral.ai/api-keys)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
MISTRAL_MODEL_FAST=mistral-small-latest

# Ollama (free, local) for AI brief generation
# Install from https://ollama.com, then run: ollama pull llama3.1:8b
OLLAMA_ENABLED=true
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434

# OpenAI (optional, paid)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Provider priority order (comma-separated). Default: groq,mistral,ollama
# The orchestrator tries each in order; first one to respond wins.
LLM_PROVIDER_ORDER=groq,mistral,ollama

# =============================================================================
# RESEARCH / SEARCH
# =============================================================================

# Tavily (free tier at https://tavily.com — 1000 searches/month)
TAVILY_API_KEY=tvly-...

# =============================================================================
# SERVER CONFIG
# =============================================================================

# CORS: allow your frontend origin (Vite dev server)
CORS_ORIGIN=http://127.0.0.1:5500

# RAG server port
RAG_PORT=8787

# =============================================================================
# CAMPAIGN FACTORY
# =============================================================================

# How often the live research agent pulls fresh news (ms)
RESEARCH_REFRESH_MS=3600000
# How long a campaign chain output stays in cache (ms)
CAMPAIGN_CACHE_TTL_MS=1800000
