# Example .env.local — copy this to .env.local and fill in your keys
# .env.local is gitignored; keep secrets there, not in .env

# Ollama (free, local) for AI brief generation
# Install from https://ollama.com, then run: ollama pull llama3.1:8b
OLLAMA_ENABLED=true
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434

# LLM provider: "ollama" (free) or "openai" (paid)
LLM_PROVIDER=ollama

# OpenAI (optional, paid)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Tavily (optional — free tier at https://tavily.com)
# TAVILY_API_KEY=tvly-...

# CORS: allow your frontend origin (Vite dev server)
CORS_ORIGIN=http://127.0.0.1:5500

# RAG server port
RAG_PORT=8787
